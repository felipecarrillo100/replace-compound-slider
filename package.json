{
  "name": "replace-compound-slider",
  "version": "4.0.3",
  "description": "Modernized fork of react-compound-slider. High-performance, lightweight, and accessible slider components for React 18 & 19.",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Steve Hall",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/felipecarrillo100/replace-compound-slider.git"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "docs": "typedoc",
    "demo:dev": "npm run build && npm run dev --prefix demo",
    "demo:watch": "concurrently \"npm run dev\" \"npm run dev --prefix demo\"",
    "demo:build": "npm run build && npm run build --prefix demo"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "typedoc": "^0.28.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
